# ═══════════════════════════════════════════════════════════════
# Chatbot Dirmik Unpad — Konfigurasi Python/AI Backend
# Salin file ini menjadi .env (di folder back-end/chatbot/)
# ═══════════════════════════════════════════════════════════════

# Wajib sama dengan Konfigurasi Node.js
MONGO_URI=mongodb+srv://admin:password@cluster.mongodb.net/?appName=chatbot
MONGO_DB_NAME=chatbot_dirmik

# Kunci API LLM Groq
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model LLM dan Embedding (dijalankan lokal)
LLM_MODEL=llama-3.3-70b-versatile
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# (Opsional) Mengubah port default backend AI
# PYTHON_PORT=8080
