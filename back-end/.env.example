# ═══════════════════════════════════════════════════════════════
# Chatbot Direktorat Akademik Unpad — Konfigurasi Node.js Backend
# Salin file ini menjadi .env (di folder back-end/) lalu isi nilainya.
# ═══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
PORT=5000

# ── MongoDB Atlas ─────────────────────────────────────────────
MONGO_URI=mongodb+srv://admin:password@cluster.mongodb.net/?appName=chatbot
MONGO_DB_NAME=chatbot_dirmik
# Nama indeks vektor yang sudah dibuat di MongoDB Atlas
MONGO_VECTOR_INDEX=vector_index

# ── JWT Secret (ganti dengan string acak yang kuat!) ──────────
JWT_SECRET=rahasia_jwt_sangat_kuat_2026_random_string

# ═══════════════════════════════════════════════════════════════
# IDENTITAS UNIT — akan digunakan oleh RAG dan Chatbot
# ═══════════════════════════════════════════════════════════════

UNIT_NAME=Direktorat Pendidikan dan Internasionalisasi
UNIT_SHORT=Direktorat Akademik
UNIV_NAME=Universitas Padjadjaran
UNIV_ABBREVIATION=Unpad
HELPDESK_CONTACT=admin@unpad.ac.id

# ── LLM & AI ──────────────────────────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
