# ═══════════════════════════════════════════════════════════════
# Chatbot Direktorat Akademik Unpad — Konfigurasi Lengkap
# Salin file ini menjadi .env lalu isi nilai yang sesuai.
# ═══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── MongoDB Atlas ─────────────────────────────────────────────
MONGO_URI=mongodb+srv://admin:password@cluster.mongodb.net/?appName=chatbot
MONGO_DB_NAME=chatbot_dirmik
# Nama indeks vektor yang sudah dibuat di MongoDB Atlas
MONGO_VECTOR_INDEX=vector_index

# ── JWT Secret (ganti dengan string acak yang kuat!) ──────────
JWT_SECRET=ganti_dengan_secret_acak_yang_sangat_panjang_dan_kuat

# ═══════════════════════════════════════════════════════════════
# IDENTITAS DIREKTORAT — sesuaikan dengan unit Anda
# ═══════════════════════════════════════════════════════════════

# Nama lengkap direktorat
UNIT_NAME=Direktorat Akademik
# Singkatan direktorat
UNIT_ABBREVIATION=Dirmik

# Nama universitas
UNIV_NAME=Universitas Padjadjaran
# Singkatan universitas
UNIV_ABBREVIATION=Unpad

# Teks helpdesk yang disebut di jawaban jika data tidak ditemukan
HELPDESK_CONTACT=admin Direktorat Akademik Unpad

# ═══════════════════════════════════════════════════════════════
# LLM Provider
# ═══════════════════════════════════════════════════════════════
# Pilihan: groq | ollama
LLM_PROVIDER=groq

# --- Groq (direkomendasikan, gratis & cepat) ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model yang tersedia: llama-3.1-8b-instant | llama-3.1-70b-versatile | mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=768

# --- Ollama (self-hosted, jika LLM_PROVIDER=ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.1

# ═══════════════════════════════════════════════════════════════
# Embedding Provider
# ═══════════════════════════════════════════════════════════════
# Pilihan: ollama | openai
EMBEDDING_PROVIDER=ollama

# --- Ollama Embedding (default, gratis) ---
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# --- OpenAI Embedding (lebih kuat, berbayar) ---
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMBEDDING_MODEL=text-embedding-3-small

# ═══════════════════════════════════════════════════════════════
# CORS — URL situs WordPress / portal direktorat Anda
# ═══════════════════════════════════════════════════════════════
# Kosongkan atau hapus untuk mengizinkan semua origin (mode development)
# WORDPRESS_URL=https://dirmik.unpad.ac.id

# ═══════════════════════════════════════════════════════════════
# RAG Tuning — opsional, default sudah dioptimalkan
# ═══════════════════════════════════════════════════════════════
# Jumlah chunk konteks yang dikirim ke LLM
# RAG_CONTEXT_CHUNKS=4
# Jumlah kandidat yang di-fetch dari vector store sebelum reranking
# RAG_FETCH_K=12
# Batas dokumen hasil pencarian keyword
# RAG_KEYWORD_LIMIT=12
# Panjang maksimum satu chunk teks (karakter)
# RAG_CHUNK_CHARS=760
# Overlap antar-chunk (karakter)
# RAG_CHUNK_OVERLAP=80
# Total karakter maksimum semua konteks yang dikirim ke LLM
# RAG_MAX_CONTEXT_CHARS=3600
# Skor minimum vektor agar chunk dipertimbangkan
# RAG_MIN_VECTOR_SCORE=0.62
# Skor minimum chunk setelah reranking
# RAG_MIN_CHUNK_SCORE=0.12
# Jumlah maksimum sumber yang ditampilkan di jawaban
# RAG_SOURCE_LIMIT=3
